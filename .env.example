# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=your_key_here

# Model ID — free tier rate-limits popular models like gemini-2.5-flash.
# Good free-tier options: meta/llama-3.1-8b, google/gemini-2.5-flash-lite
# Browse: https://vercel.com/ai-gateway/models
AI_GATEWAY_MODEL=meta/llama-3.1-8b

# Optional comma-separated fallbacks if the primary model fails or is rate-limited
# AI_GATEWAY_MODEL_FALLBACKS=google/gemini-2.5-flash-lite,openai/gpt-4o-mini,anthropic/claude-3-haiku
