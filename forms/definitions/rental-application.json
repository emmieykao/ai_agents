    },
    {
      "id": "email",
      "label": "Email Address",
      "type": "email",
      "required": true
    },
    {
      "id": "phone",
      "label": "Phone Number",
      "type": "phone",
      "required": true
    },
    {
      "id": "address",
      "label": "Current Address",
      "type": "text",
      "required": false
    },
    {
      "id": "employer",
      "label": "Current Employer",
      "type": "text",
      "required": false
    },
    {
      "id": "job_title",
      "label": "Occupation / Job Title",
      "type": "text",
      "required": false
    },
    {
      "id": "years_experience",
