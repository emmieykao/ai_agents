{
  "name": "ai_agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI agent that reads and answers questions about documents using the Vercel AI SDK",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm run typecheck --prefix web",
    "create-sample-pdf": "tsx scripts/create-sample-pdf-form.ts",
    "create-sample-document-pdf": "tsx scripts/create-sample-document-pdf.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ai": "^6.0.205",
    "dotenv": "^17.4.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
